{
  "name": "tfnsw-route-planner",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "TfNSW Route Planner monorepo: backend service layer, mobile-first web frontend, and shared code.",
  "workspaces": [
    "shared",
    "backend",
    "frontend"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "dev": "concurrently -n backend,frontend -c blue,green \"npm:dev:backend\" \"npm:dev:frontend\"",
    "dev:backend": "npm run dev --workspace @tfnsw/backend",
    "dev:frontend": "npm run dev --workspace @tfnsw/frontend",
    "smoke": "npm run smoke --workspace @tfnsw/backend"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@types/node": "^22.10.0",
    "concurrently": "^9.1.0",
    "eslint": "^9.17.0",
    "fast-check": "^3.23.1",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.0",
    "vitest": "^2.1.8"
  }
}
