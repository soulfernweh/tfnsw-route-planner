# TfNSW Route Planner environment variables
# Copy this file to `.env` and fill in real values locally.
# NEVER commit `.env` or real secret values.

# API key for the Transport for NSW Trip Planner API (Open Data Hub).
# Injected by the backend only as: Authorization: apikey <TFNSW_API_KEY>
TFNSW_API_KEY=

# Base URL for the TfNSW Trip Planner API.
# Example: https://api.transport.nsw.gov.au
TFNSW_BASE_URL=

# Comma-separated list of allowed CORS origins for the backend.
# Example: http://localhost:5173,https://routes.example.com
ALLOWED_ORIGINS=
